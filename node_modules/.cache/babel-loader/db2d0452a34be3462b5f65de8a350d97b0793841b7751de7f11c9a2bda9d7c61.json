le URL\" onChange={e => setFile({...file, url: e.target.value})} />\n          <button onClick={() => call('sendFileByUrl', file.phone, file.url)} disabled={loading}>sendFileByUrl</button>\n        </div>\n      </div>\n\n      <div className=\"output-section\">\n        <label>Response:</label>\n        <textarea readOnly value={JSON.stringify(response, null, 2)} />\n      </div>\n    </div>\n  );\n};\n\nexport default App;\n"],"mappings":"AAAA,MAAO,CAAAA,KAAK,EAAIC,QAAQ,KAAQ,OAAO,CACvC,OAASC,WAAW,KAAQ,qBAAqB,CACjD,MAAO,WAAW,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAEnB,KAAM,CAAAC,GAAG,CAAGA,CAAA,GAAM,CAChB,KAAM,CAACC,IAAI,CAAEC,OAAO,CAAC,CAAGR,QAAQ,CAAC,CAAES,EAAE,CAAE,EAAE,CAAEC,KAAK,CAAE,EAAG,CAAC,CAAC,CACvD,KAAM,CAACC,GAAG,CAAEC,MAAM,CAAC,CAAGZ,QAAQ,CAAC,CAAEa,KAAK,CAAE,EAAE,CAAEC,IAAI,CAAE,EAAG,CAAC,CAAC,CACvD,KAAM,CAACC,IAAI,CAAEC,OAAO,CAAC,CAAGhB,QAAQ,CAAC,CAAEa,KAAK,CAAE,EAAE,CAAEI,GAAG,CAAE,EAAG,CAAC,CAAC,CAExD,KAAM,CAAEC,QAAQ,CAAEC,OAAO,CAAEC,IAAK,CAAC,CAAGnB,WAAW,CAACM,IAAI,CAACE,EAAE,CAAEF,IAAI,CAACG,KAAK,CAAC,CAEpE,mBACEL,KAAA,QAAKgB,SAAS,CAAC,WAAW,CAAAC,QAAA,eACxBjB,KAAA,QAAKgB,SAAS,CAAC,eAAe,CAAAC,QAAA,eAC5BjB,KAAA,QAAKgB,SAAS,CAAC,OAAO,CAAAC,QAAA,eACpBnB,IAAA,UAAOoB,WAAW,CAAC,YAAY,CAACC,QAAQ,CAAEC,CAAC,EAAIjB,OAAO,CAAC,CAAC,GAAGD,IAAI,CAAEE,EAAE,CAAEgB,CAAC,CAACC,MAAM,CAACC,KAAK,CAAC,CAAE,CAAE,CAAC,cACzFxB,IAAA,UAAOoB,WAAW,CAAC,kBAAkB,CAACC,QAAQ,CAAEC,CAAC,EAAIjB,OAAO,CAAC,CAAC,GAAGD,IAAI,CAAEG,KAAK,CAAEe,CAAC,CAACC,MAAM,CAACC,KAAK,CAAC,CAAE,CAAE,CAAC,cAClGxB,IAAA,WAAQyB,OAAO,CAAEA,CAAA,GAAMR,IAAI,CAAC,aAAa,CAAE,CAACS,QAAQ,CAAEV,OAAQ,CAAAG,QAAA,CAAC,aAAW,CAAQ,CAAC,cACnFnB,IAAA,WAAQyB,OAAO,CAAEA,CAAA,GAAMR,IAAI,CAAC,kBAAkB,CAAE,CAACS,QAAQ,CAAEV,OAAQ,CAAAG,QAAA,CAAC,kBAAgB,CAAQ,CAAC,EAC1F,CAAC,cAENjB,KAAA,QAAKgB,SAAS,CAAC,OAAO,CAAAC,QAAA,eACpBnB,IAAA,UAAOoB,WAAW,CAAC,aAAa,CAACC,QAAQ,CAAEC,CAAC,EAAIb,MAAM,CAAC,CAAC,GAAGD,GAAG,CAAEE,KAAK,CAAEY,CAAC,CAACC,MAAM,CAACC,KAAK,CAAC,CAAE,CAAE,CAAC,cAC3FxB,IAAA,aAAUoB,WAAW,CAAC,SAAS,CAACC,QAAQ,CAAEC,CA